# Core Supabase configuration (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional feature flags
NEXT_PUBLIC_ENABLE_GOOGLE_DRIVE=false
NEXT_PUBLIC_ENABLE_DRIVE_SYNC=false
NEXT_PUBLIC_ENABLE_DRIVE_ATTACHMENTS=false
NEXT_PUBLIC_DEV_AUTH=false

# Application base URL for callback and webhook generation
# Recommended for production deployment.
NEXT_PUBLIC_APP_URL=

# Google Drive / OAuth configuration (optional)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_DRIVE_REDIRECT_URI=
GOOGLE_DRIVE_WEBHOOK_CALLBACK_URL=
DRIVE_TOKEN_ENCRYPTION_KEY=

# Optional integrations
GOOGLE_CLOUD_VISION_API_KEY=
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
NEXT_PUBLIC_STORAGE_REGION=
